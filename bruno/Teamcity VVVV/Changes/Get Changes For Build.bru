meta {
  name: Get Changes For Build
  type: http
  seq: 3
}

get {
  url: {{vvvv-teamcity-rest}}/changes?locator=build:(id:{{build-id}})&fields=count,change:(version,username,date,href,comment,files)
  body: none
  auth: inherit
}

params:query {
  locator: build:(id:{{build-id}})
  fields: count,change:(version,username,date,href,comment,files)
}

vars:pre-request {
  build-id: 39025
}
